# Postgres connection string used by the app at runtime. Works with any
# Postgres-compatible host — Neon, Supabase, Vercel Postgres, Railway, RDS,
# or a local instance:
DATABASE_URL="postgresql://user:password@host:5432/ascend"

# For local development, the simplest path is a local Postgres:
#   createdb ascend
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ascend"

# For serverless hosting (Vercel and similar), each function invocation opens
# its own database connection, so use your provider's *pooled* connection
# string for DATABASE_URL, e.g.:
#   Neon:     the "pooled connection" string from the Neon dashboard
#   Supabase: the "Transaction pooler" string (port 6543), not "Direct connection"
#   Vercel Postgres: the POSTGRES_PRISMA_URL env var it provisions for you

# DIRECT_URL — an *unpooled* connection, used only when running migrations
# (`prisma migrate deploy`/`dev`, e.g. via the `vercel-build` script).
# Migrations hold an advisory lock that a transaction-mode pooler breaks, so
# this must bypass the pooler. Only needed on hosts that put migrations
# behind a transaction pooler by default — mainly Supabase:
#   Supabase: the "Session pooler" string (still IPv4-reachable, unlike
#             "Direct connection", but not transaction-mode pooled)
#   Neon / Vercel Postgres: usually unnecessary — DIRECT_URL falls back to
#             DATABASE_URL automatically if unset
# DIRECT_URL="postgresql://user:password@host:5432/ascend"
