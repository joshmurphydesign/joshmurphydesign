# SQLite for local/sandbox development — zero setup required.
# For a real deployment on serverless infra (e.g. Vercel), SQLite's file-based
# storage won't persist across function invocations. Swap this for a hosted
# Postgres connection string instead (the schema is written to be compatible):
#   DATABASE_URL="postgresql://user:password@host:5432/ascend"
DATABASE_URL="file:./dev.db"
